# Django Configuration
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,frp3.ccszxc.xin

# Database (SQLite for development, PostgreSQL for production)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# For PostgreSQL (comment out SQLite settings above):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=metabase_chat
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

# MCP Server Configuration
MCP_SERVER_URL=http://localhost:8000

# Metabase Configuration
METABASE_URL=http://localhost:3000
METABASE_API_KEY=your-metabase-api-key
METABASE_EMBED_KEY=your-metabase-embedding-secret-key

# OpenAI API (for natural language to SQL conversion)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# JWT Configuration (optional, defaults to SECRET_KEY)
# JWT_SECRET_KEY=your-jwt-secret-key

# Django Server Configuration
# Default: 8001 (to avoid conflict with MCP server on 8000)
# You can change this if needed
# DJANGO_PORT=8001
